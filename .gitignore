node_modules/
dist/
.claude/
.DS_Store

# Foreman working docs (specs, ledgers, pentest artifacts)
Docs/

# Repository documentation is committed.
!docs/
!docs/**

# Local experiment workspace. Keep only the folder marker in git so review
# tooling does not scan synthetic target applications or generated outputs.
Test_dojo/**
!Test_dojo/
!Test_dojo/.gitkeep

# Local package/install artifacts
foreman-mcp/.npm-cache/
foreman-mcp/*.tgz

# Keep assets/ but ignore generation prompts
assets/prompts.md

# CI-only release pack output. The committed artifacts/ folder is the
# archival history; release-pkg/ is the per-build staging dir used by the
# build workflow so the Release upload only ships the current version.
release-pkg/
